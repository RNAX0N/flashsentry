[Desktop Entry]
Type=Application
Name=FlashSpartan
GenericName=USB Security Monitor
Comment=Verify Linux ISOs and USB sticks — automatic checksums, PGP, and folder watch lists
Exec=flashspartan %U
Icon=flashspartan
Terminal=false
Categories=System;Security;Utility;
Keywords=USB;ISO;Linux;security;hash;verify;gpg;Rufus;checksum;Merkle;
StartupNotify=true
StartupWMClass=FlashSpartan

# Actions for right-click menu
Actions=minimized;settings;

[Desktop Action minimized]
Name=Start Minimized
Exec=flashspartan --minimized

[Desktop Action settings]
Name=Open Settings
Exec=flashspartan --settings

# Translations
Name[de]=FlashSpartan
Comment[de]=USB-Flash-Laufwerke überwachen und verifizieren
Name[es]=FlashSpartan
Comment[es]=Monitorear y verificar unidades flash USB
Name[fr]=FlashSpartan
Comment[fr]=Surveiller et vérifier les clés USB
Name[ja]=FlashSpartan
Comment[ja]=USBフラッシュドライブの監視と検証
Name[zh_CN]=FlashSpartan
Comment[zh_CN]=监控和验证USB闪存驱动器
