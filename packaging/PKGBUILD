# Maintainer: FlashSentry Team <team@flashsentry.io>
#
# Install from a git checkout (recommended):
#   cd packaging && ./build-package.sh -si
#
# Install from a release tag (requires v${pkgver} on GitHub):
#   cd packaging && FLASHSENTRY_RELEASE=1 makepkg -si
#
pkgname=flashsentry
pkgver=1.4.2
pkgrel=6
pkgdesc="USB and ISO security monitor - verify Linux ISOs, watch folders, optional full-disk hash"
arch=('x86_64' 'aarch64')
url="https://github.com/RNAX0N/flashsentry"
license=('MIT')
depends=(
    'qt6-base'
    'openssl'
    'systemd-libs'
    'udisks2'
    'polkit'
)
makedepends=(
    'cmake'
    'git'
    'qt6-tools'
    'pkgconf'
    'rsync'
)
optdepends=(
    'libnotify: Desktop notifications support'
    'qt6-wayland: Wayland support'
    'gnupg: Automatic ISO OpenPGP signature verification'
)
provides=('flashsentry')
conflicts=('flashsentry-git')
backup=('etc/flashsentry/config.json')
install=flashsentry.install

_repo_root="$(cd -- "${startdir}/.." && pwd)"
_staging="${srcdir}/${pkgname}-${pkgver}"

if [ "${FLASHSENTRY_RELEASE:-0}" = 1 ]; then
    source=(
        "${pkgname}-${pkgver}.tar.gz::https://github.com/RNAX0N/flashsentry/archive/refs/tags/v${pkgver}.tar.gz"
    )
    sha256sums=('SKIP')
else
    source=()
    sha256sums=()
fi

prepare() {
  if [ "${FLASHSENTRY_RELEASE:-0}" != 1 ]; then
    rm -rf "${_staging}"
    mkdir -p "${_staging}"
    rsync -a --delete \
      --exclude 'pkg' \
      --exclude 'packaging/pkg' \
      --exclude 'packaging/src' \
      --exclude 'build' \
      --exclude 'packaging/build' \
      "${_repo_root}/" "${_staging}/"
  fi
  cd "${_staging}"
  mkdir -p build
}

build() {
  cd "${_staging}/build"
  cmake .. \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DFLASHSENTRY_BUILD_TESTS=ON \
    -Wno-dev
  cmake --build . --parallel
}

check() {
  cd "${_staging}/build"
  if [ -f CTestTestfile.cmake ]; then
    ctest --output-on-failure
  fi
}

package() {
  cd "${_staging}/build"
  DESTDIR="${pkgdir}" cmake --install .

  install -Dm644 "${_staging}/packaging/config.json.default" \
    "${pkgdir}/etc/flashsentry/config.json" 2>/dev/null || true

  for size in 16 32 48 64 128 256; do
    if [ -f "${_staging}/resources/icons/flashsentry-${size}.png" ]; then
      install -Dm644 "${_staging}/resources/icons/flashsentry-${size}.png" \
        "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/flashsentry.png"
    fi
  done

  install -Dm644 "${_staging}/resources/icons/flashsentry.svg" \
    "${pkgdir}/usr/share/icons/hicolor/scalable/apps/flashsentry.svg"

  if [ -f "${_staging}/packaging/flashsentry.bash" ]; then
    install -Dm644 "${_staging}/packaging/flashsentry.bash" \
      "${pkgdir}/usr/share/bash-completion/completions/flashsentry"
  fi

  if [ -f "${_staging}/packaging/flashsentry.zsh" ]; then
    install -Dm644 "${_staging}/packaging/flashsentry.zsh" \
      "${pkgdir}/usr/share/zsh/site-functions/_flashsentry"
  fi
}

# vim:set ts=4 sw=4 et:
