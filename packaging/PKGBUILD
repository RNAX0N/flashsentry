# Maintainer: FlashSpartan Team <team@flashspartan.io>
#
# Install from a git checkout (recommended):
#   cd packaging && ./build-package.sh -si
#
# Install from a release tag (requires v${pkgver} on GitHub):
#   cd packaging && FLASHSPARTAN_RELEASE=1 makepkg -si
#
pkgname=flashspartan
pkgver=1.4.2
pkgrel=7
pkgdesc="USB and ISO security monitor - verify Linux ISOs, watch folders, optional full-disk hash"
arch=('x86_64' 'aarch64')
url="https://github.com/RNAX0N/flashspartan"
license=('MIT')
depends=(
    'qt6-base'
    'openssl'
    'systemd-libs'
    'udisks2'
    'polkit'
)
makedepends=(
    'cmake'
    'git'
    'qt6-tools'
    'pkgconf'
    'rsync'
)
optdepends=(
    'libnotify: Desktop notifications support'
    'qt6-wayland: Wayland support'
    'gnupg: Automatic ISO OpenPGP signature verification'
)
provides=('flashspartan')
conflicts=('flashspartan-git')
backup=('etc/flashspartan/config.json')
install=flashspartan.install

_repo_root="$(cd -- "${startdir}/.." && pwd)"

_staging_dir() {
  printf '%s/%s-%s' "${srcdir}" "${pkgname}" "${pkgver}"
}

if [ "${FLASHSPARTAN_RELEASE:-0}" = 1 ]; then
    source=(
        "${pkgname}-${pkgver}.tar.gz::https://github.com/RNAX0N/flashspartan/archive/refs/tags/v${pkgver}.tar.gz"
    )
    sha256sums=('SKIP')
else
    source=()
    sha256sums=()
fi

prepare() {
  if [ "${FLASHSPARTAN_RELEASE:-0}" != 1 ]; then
    local staging="$(_staging_dir)"
    rm -rf "${staging}"
    mkdir -p "${staging}"
    rsync -a --delete \
      --exclude 'pkg' \
      --exclude 'packaging/pkg' \
      --exclude 'packaging/src' \
      --exclude 'build' \
      --exclude 'packaging/build' \
      "${_repo_root}/" "${staging}/"
  fi
  cd "$(_staging_dir)"
  mkdir -p build
}

build() {
  cd "$(_staging_dir)/build"
  cmake .. \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DFLASHSPARTAN_BUILD_TESTS=ON \
    -Wno-dev
  cmake --build . --parallel
}

check() {
  cd "$(_staging_dir)/build"
  if [ -f CTestTestfile.cmake ]; then
    ctest --output-on-failure
  fi
}

package() {
  local root="$(_staging_dir)"
  cd "${root}/build"
  DESTDIR="${pkgdir}" cmake --install .

  install -Dm644 "${root}/packaging/config.json.default" \
    "${pkgdir}/etc/flashspartan/config.json" 2>/dev/null || true

  for size in 16 32 48 64 128 256; do
    if [ -f "${root}/resources/icons/flashspartan-${size}.png" ]; then
      install -Dm644 "${root}/resources/icons/flashspartan-${size}.png" \
        "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/flashspartan.png"
    fi
  done

  install -Dm644 "${root}/resources/icons/flashspartan.svg" \
    "${pkgdir}/usr/share/icons/hicolor/scalable/apps/flashspartan.svg"

  install -Dm644 "${root}/packaging/flashspartan.service" \
    "${pkgdir}/usr/lib/systemd/user/flashspartan.service"

  if [ -f "${root}/packaging/flashspartan.bash" ]; then
    install -Dm644 "${root}/packaging/flashspartan.bash" \
      "${pkgdir}/usr/share/bash-completion/completions/flashspartan"
  fi

  if [ -f "${root}/packaging/flashspartan.zsh" ]; then
    install -Dm644 "${root}/packaging/flashspartan.zsh" \
      "${pkgdir}/usr/share/zsh/site-functions/_flashspartan"
  fi
}

# vim:set ts=4 sw=4 et:
